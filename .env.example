# YourVoiceYourNotes — local development
GCP_PROJECT_ID=your-gcp-project-id
GCP_BUCKET_NAME=your-audio-bucket
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
# On App Engine: omit GOOGLE_APPLICATION_CREDENTIALS; set GCP_* in app.yaml instead.

# Optional (Speech-to-Text), default en-US
SPEECH_LANGUAGE_CODE=en-US

# Optional (Text-to-Speech): fallback voice if request omits voiceName.
# Must match a name from lib/tts-voices.ts.
TTS_VOICE_NAME=en-US-Neural2-F
